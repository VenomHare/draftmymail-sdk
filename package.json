{
  "name": "draftmymail",
  "version": "1.0.1",
  "description": "TypeScript SDK for generating emails with DraftMyMail AI.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist"
  },
  "keywords": [],
  "author": "VenomHare <https://github.com/VenomHare>",
  "repository": {
    "type": "git",
    "url": "https://github.com/VenomHare/draftmymail-sdk"
  },
  "homepage": "https://github.com/VenomHare/draftmymail-sdk?tab=readme-ov-file",
  "bugs": {
    "url": "https://github.com/VenomHare/draftmymail-sdk/issues"
  }
